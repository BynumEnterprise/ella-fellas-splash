list-text","name":"Title","settings":{"text":"<h3>Fan Favorites</h3>","type_preset":"h3","font":"var(--font-heading--family)","alignment":"left","width":"fit-content"},"blocks":{}},"plb":{"type":"_product-list-button","name":"Button","settings":{"label":"Shop all products →","style_class":"link","width":"fit-content"},"blocks":{}}},"block_order":["plt","plb"]},"static-product-card":{"type":"_product-card","name":"Card","static":true,"settings":{"product_card_gap":6,"border":"none","border_radius":10},"blocks":{"g":{"type":"_product-card-gallery","name":"Media","settings":{"image_ratio":"square","border":"none","border_radius":10},"blocks":{}},"ti":{"type":"product-title","name":"Title","settings":{"type_preset":"rte","font":"var(--font-body--family)","alignment":"left","width":"100%","padding-block-start":6},"blocks":{}},"pr":{"type":"price","name":"Price","settings":{"show_sale_price_first":true,"type_preset":"h6","font":"var(--font-heading--family)","alignment":"left","width":"100%"},"blocks":{}}},"block_order":["g","ti","pr"]}},"name":"Product list","settings":{"collection":"ella-fellas-collection","layout_type":"grid","carousel_on_mobile":true,"max_products":8,"columns":4,"mobile_columns":"2","mobile_card_size":"60cqw","columns_gap":14,"rows_gap":28,"icons_style":"arrow","icons_shape":"circle","section_width":"page-width","horizontal_alignment":"flex-start","gap":24,"background_color":"{{ settings.color_palette.background }}","padding-block-start":40,"padding-block-end":56}},"spotlight":{"type":"custom-liquid","blocks":{},"settings":{"custom_liquid":"\n<style>\n.ef2-spot{display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center;max-width:1150px;margin:0 auto;padding:64px 40px}\n.ef2-spot-imgwrap{position:relative}\n.ef2-spot-img{width:100%;border-radius:14px;box-shadow:0 18px 44px rgba(43,36,34,.25);display:block}\n.ef2-spot-img2{position:absolute;width:44%;right:-6%;bottom:-10%;border-radius:12px;border:6px solid #F7F1E4;box-shadow:0 14px 30px rgba(43,36,34,.3);transform:rotate(5deg)}\n.ef2-spot h2{font-family:var(--font-heading--family);font-size:clamp(1.9rem,3.4vw,2.7rem);color:#2B2422;line-height:1.1;margin:0 0 14px}\n.ef2-spot .ef2-eyebrow{font-family:var(--font-body--family);font-weight:700;font-size:.78rem;letter-spacing:.22em;text-transform:uppercase;color:#B8563A;margin:0 0 12px}\n.ef2-spot p{font-family:var(--font-body--family);font-size:1.02rem;line-height:1.65;color:#4A403C;margin:0 0 24px}\n.ef2-spot .ef2-btn-p{background:#2B2422;color:#F7F1E4;box-shadow:0 6px 18px rgba(43,36,34,.3)}\n.ef2-spot-link{display:inline-block;margin-left:18px;font-family:var(--font-body--family);font-weight:700;color:#B8563A;text-decoration:underline;text-underline-offset:4px}\n@media(max-width:860px){.ef2-spot{grid-template-columns:1fr;padding:44px 20px;gap:40px}}\n</style>\n<div class=\"ef2-spot\">\n  <div class=\"ef2-spot-imgwrap\">\n    <img class=\"ef2-spot-img\" src=\"https://cdn.shopify.com/s/files/1/0775/4799/5293/files/14998726495850199840_2048.jpg?v=1784659672&width=700\" alt=\"Ella Fellas trucker cap\" loading=\"lazy\">\n    <img class=\"ef2-spot-img ef2-spot-img2\" src=\"https://cdn.shopify.com/s/files/1/0775/4799/5293/files/16191783920598050290_2048.jpg?v=1784658089&width=700\" alt=\"Womens Ella Fellas tee\" loading=\"lazy\">\n  </div>\n  <div>\n    <p class=\"ef2-eyebrow\">His &amp; hers</p>\n    <h2>Yes, the fellas get their own line.</h2>\n    <p>\"I'm an Ella Fella\" tees, trucker caps and shot glasses built for the guys &mdash; plus wildflower crops, dandelion tanks and cozy crews for the girls who brought them to the show in the first place.</p>\n    <div>\n      <a class=\"ef2-btn ef2-btn-p\" style=\"display:inline-block;padding:1rem 1.9rem;border-radius:10px;font-weight:700;text-decoration:none;font-family:var(--font-body--family)\" href=\"/collections/mens-favorites\">Shop men's</a>\n      <a class=\"ef2-spot-link\" href=\"/collections/womens-favorites\">Shop women's &rarr;</a>\n    </div>\n  </div>\n</div>\n","background_color":"#EFE5CF","section_width":"full-width","padding-block-start":0,"padding-block-end":0}},"testimonials":{"type":"custom-liquid","blocks":{},"settings":{"custom_liquid":"\n<style>\n.ef2-tests{max-width:1150px;margin:0 auto;padding:56px 40px;text-align:center}\n.ef2-tests h2{font-family:var(--font-heading--family);font-size:clamp(1.8rem,3vw,2.4rem);color:#F7F1E4;margin:0 0 8px}\n.ef2-tests .ef2-tsub{font-family:var(--font-body--family);color:#CBBFAF;margin:0 0 34px}\n.ef2-tgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}\n.ef2-tcard{background:#F7F1E4;border-radius:14px;padding:26px 22px;text-align:left;box-shadow:0 10px 26px rgba(0,0,0,.25)}\n.ef2-stars{color:#B8873A;letter-spacing:.15em;font-size:1rem;margin-bottom:10px}\n.ef2-tcard p{font-family:var(--font-body--family);font-size:.95rem;line-height:1.6;color:#2B2422;margin:0 0 14px}\n.ef2-tcard cite{font-family:var(--font-heading--family);font-style:normal;font-size:.85rem;color:#B8563A}\n@media(max-width:820px){.ef2-tgrid{grid-template-columns:1fr}.ef2-tests{padding:44px 20px}}\n</style>\n<div class=\"ef2-tests\">\n  <h2>Fans are talking</h2>\n  <p class=\"ef2-tsub\">Straight from the wildflower-and-whiskey crowd.</p>\n  <div class=\"ef2-tgrid\">\n    <div class=\"ef2-tcard\"><div class=\"ef2-stars\">&#9733;&#9733;&#9733;&#9733;&#9733;</div><p>\"Wore my Wildflowers &amp; Whiskey tee to the show and three people asked where I got it. Print quality is legit.\"</p><cite>&mdash; Kayla R.</cite></div>\n    <div class=\"ef2-tcard\"><div class=\"ef2-stars\">&#9733;&#9733;&#9733;&#9733;&#9733;</div><p>\"Bought the 'I'm an Ella Fella' tee as a joke for my boyfriend. He wears it more than anything else he owns.\"</p><cite>&mdash; Morgan T.</cite></div>\n    <div class=\"ef2-tcard\"><div class=\"ef2-stars\">&#9733;&#9733;&#9733;&#9733;&#9733;</div><p>\"The sunset hoodie is my new cold-weather uniform. Soft, heavy, and the colors actually pop in person.\"</p><cite>&mdash; Jess D.</cite></div>\n  </div>\n</div>\n","background_color":"#2B2422","section_width":"full-width","padding-block-start":0,"padding-block-end":0}},"brand_story":{"type":"custom-liquid","blocks":{},"settings":{"custom_liquid":"\n<style>\n.ef2-story{max-width:820px;margin:0 auto;padding:64px 40px;text-align:center}\n.ef2-story .ef2-rule{color:#B8873A;font-size:1.1rem;letter-spacing:.5em;margin-bottom:14px}\n.ef2-story h2{font-family:var(--font-heading--family);font-size:clamp(1.9rem,3.4vw,2.7rem);color:#2B2422;margin:0 0 16px}\n.ef2-story p{font-family:var(--font-body--family);font-size:1.05rem;line-height:1.7;color:#4A403C;margin:0 0 26px}\n.ef2-story a{display:inline-block;padding:1rem 1.9rem;border-radius:10px;background:#B8563A;color:#F7F1E4;font-family:var(--font-body--family);font-weight:700;text-decoration:none;box-shadow:0 6px 18px rgba(184,86,58,.35)}\n@media(max-width:760px){.ef2-story{padding:44px 20px}}\n</style>\n<div class=\"ef2-story\">\n  <div class=\"ef2-rule\">&#10022; &#10022; &#10022;</div>\n  <h2>Made by fans. For fans.</h2>\n  <p>Ella Fellas started the way all good country stories do &mdash; a show, a crowd singing louder than the speakers, and the feeling you never want it to end. We turn that feeling into bold western graphics: dandelions, longhorns, neon marquees and desert sunsets, printed to order on quality blanks so nothing sits in a warehouse and nothing goes to waste.</p>\n  <a href=\"/collections/ella-fellas-collection\">See the whole collection</a>\n</div>\n","background_color":"#F7F1E4","section_width":"full-width","padding-block-start":0,"padding-block-end":0}},"faq_v2":{"type":"custom-liquid","blocks":{},"settings":{"custom_liquid":"\n<style>\n.ef2-faq{max-width:760px;margin:0 auto;padding:52px 40px}\n.ef2-faq h2{font-family:var(--font-heading--family);font-size:clamp(1.6rem,2.6vw,2.1rem);color:#2B2422;text-align:center;margin:0 0 26px}\n.ef2-faq details{background:#F7F1E4;border:1.5px solid #DCCFB4;border-radius:12px;margin-bottom:12px;overflow:hidden}\n.ef2-faq summary{cursor:pointer;padding:18px 22px;font-family:var(--font-body--family);font-weight:700;color:#2B2422;list-style:none;position:relative}\n.ef2-faq summary::after{content:\"+\";position:absolute;right:20px;top:14px;font-size:1.4rem;color:#B8563A}\n.ef2-faq details[open] summary::after{content:\"\\2212\"}\n.ef2-faq details p{font-family:var(--font-body--family);font-size:.95rem;line-height:1.6;color:#4A403C;margin:0;padding:0 22px 18px}\n@media(max-width:760px){.ef2-faq{padding:40px 20px}}\n</style>\n<div class=\"ef2-faq\">\n  <h2>Good to know</h2>\n  <details><summary>When will my order ship?</summary><p>Every piece is printed just for you. Production takes 2&ndash;5 business days, then standard US shipping is another 3&ndash;5. You'll get tracking the moment it leaves the print shop.</p></details>\n  <details><summary>How does sizing run?</summary><p>True to size on our unisex tees and hoodies &mdash; size up for an oversized fit. Every product page has a detailed size chart with exact garment measurements.</p></details>\n  <details><summary>What if something's wrong with my order?</summary><p>Misprints and damaged items are replaced free, no questions asked. Everything else is covered by easy 30-day returns.</p></details>\n</div>\n","background_color":"#EFE5CF","section_width":"full-width","padding-block-start":0,"padding-block-end":0}},"newsletter_v2":{"type":"custom-liquid","blocks":{},"settings":{"custom_liquid":"\n<style>\n.ef2-news{max-width:680px;margin:0 auto;padding:56px 40px;text-align:center}\n.ef2-news h2{font-family:var(--font-heading--family);font-size:clamp(1.8rem,3vw,2.4rem);color:#2B2422;margin:0 0 10px}\n.ef2-news p{font-family:var(--font-body--family);color:#2B2422;margin:0 0 22px;line-height:1.6}\n.ef2-form{display:flex;gap:10px;flex-wrap:wrap;justify-content:center}\n.ef2-form input[type=email]{flex:1;min-width:240px;padding:1rem 1.1rem;border:2px solid #2B2422;border-radius:10px;font-size:1rem;background:#F7F1E4;color:#2B2422;font-family:var(--font-body--family)}\n.ef2-form button{padding:1rem 1.8rem;border:none;border-radius:10px;background:#2B2422;color:#F7F1E4;font-weight:700;font-size:1rem;cursor:pointer;font-family:var(--font-body--family);box-shadow:0 6px 16px rgba(43,36,34,.3)}\n.ef2-news small{display:block;margin-top:12px;font-family:var(--font-body--family);color:#5d4d33;font-size:.8rem}\n@media(max-width:760px){.ef2-news{padding:44px 20px}}\n</style>\n<div class=\"ef2-news\">\n  <h2>Join the Fan Club</h2>\n  <p>First dibs on new drops, tour-week deals and wildflower giveaways. No spam &mdash; just good country.</p>\n  {% form 'customer' %}\n    {% if form.posted_successfully? %}<p style=\"font-weight:700\">Yeehaw &mdash; you're in! Check your inbox.</p>{% endif %}\n    <input type=\"hidden\" name=\"contact[tags]\" value=\"newsletter\">\n    <div class=\"ef2-form\">\n      <input type=\"email\" name=\"contact[email]\" placeholder=\"you@example.com\" required>\n      <button type=\"submit\">Sign me up</button>\n    </div>\n  {% endform %}\n  <small>One or two emails a week, tops. Unsubscribe anytime.</small>\n</div>\n","background_color":"#B8873A","section_width":"full-width","padding-block-start":0,"padding-block-end":0}}},"order":["hero_v2","value_bar","cats_bento","favorites","spotlight","testimonials","brand_story","faq_v2","newsletter_v2"]}