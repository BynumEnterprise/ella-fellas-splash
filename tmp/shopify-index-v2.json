{"sections":{"hero_v2":{"type":"custom-liquid","blocks":{},"settings":{"custom_liquid":"\n<style>\n.ef2-hero{display:grid;grid-template-columns:1.05fr .95fr;gap:48px;align-items:center;max-width:1200px;margin:0 auto;padding:64px 40px 72px}\n.ef2-eyebrow{font-family:var(--font-body--family);font-weight:700;font-size:.78rem;letter-spacing:.22em;text-transform:uppercase;color:#B8563A;margin:0 0 14px}\n.ef2-h1{font-family:var(--font-heading--family);font-size:clamp(2.6rem,5.2vw,4.3rem);line-height:1.04;color:#2B2422;margin:0 0 18px}\n.ef2-h1 em{font-style:normal;color:#B8563A}\n.ef2-sub{font-family:var(--font-body--family);font-size:1.08rem;line-height:1.6;color:#4A403C;max-width:34rem;margin:0 0 26px}\n.ef2-ctas{display:flex;gap:14px;flex-wrap:wrap;margin:0 0 22px}\n.ef2-btn{display:inline-block;padding:1rem 1.9rem;border-radius:10px;font-family:var(--font-body--family);font-weight:700;font-size:1rem;text-decoration:none;transition:transform .15s ease, box-shadow .15s ease}\n.ef2-btn:hover{transform:translateY(-2px)}\n.ef2-btn-p{background:#B8563A;color:#F7F1E4;box-shadow:0 6px 18px rgba(184,86,58,.35)}\n.ef2-btn-s{background:transparent;color:#2B2422;border:2px solid #2B2422}\n.ef2-ticks{display:flex;gap:18px;flex-wrap:wrap;font-family:var(--font-body--family);font-size:.85rem;color:#4A403C}\n.ef2-ticks span::before{content:\"\\2714\";color:#B8873A;font-weight:700;margin-right:6px}\n.ef2-collage{position:relative;min-height:460px}\n.ef2-burst{position:absolute;inset:0;margin:auto;width:420px;height:420px;border-radius:50%;background:radial-gradient(circle,#B8873A 0%,#B8873A 55%,transparent 56%);opacity:.25}\n.ef2-card{position:absolute;width:46%;border-radius:12px;border:6px solid #fff;box-shadow:0 14px 34px rgba(43,36,34,.28);overflow:hidden;background:#fff}\n.ef2-card img{display:block;width:100%;height:auto}\n.ef2-c1{left:2%;top:6%;transform:rotate(-5deg);z-index:2}\n.ef2-c2{right:4%;top:0;transform:rotate(4deg);z-index:1;width:42%}\n.ef2-c3{left:26%;bottom:0;transform:rotate(-2deg);z-index:3;width:44%}\n.ef2-badge{position:absolute;right:6%;bottom:14%;z-index:4;background:#2B2422;color:#F7F1E4;font-family:var(--font-heading--family);font-size:.9rem;letter-spacing:.08em;padding:.6rem 1rem;border-radius:999px;transform:rotate(6deg);box-shadow:0 8px 20px rgba(43,36,34,.35)}\n@media(max-width:860px){.ef2-hero{grid-template-columns:1fr;padding:40px 20px 48px;gap:32px}.ef2-collage{min-height:340px}.ef2-burst{width:300px;height:300px}}\n</style>\n<div class=\"ef2-hero\">\n  <div>\n    <p class=\"ef2-eyebrow\">The unofficial Ella Langley fan shop</p>\n    <h1 class=\"ef2-h1\">Wildflower soul.<br><em>Whiskey</em> heart.</h1>\n    <p class=\"ef2-sub\">Bold, original western merch for fans who sing every word &mdash; tees, hoodies and drinkware printed to order in the USA, so every piece is made just for you.</p>\n    <div class=\"ef2-ctas\">\n      <a class=\"ef2-btn ef2-btn-p\" href=\"/collections/all\">Shop the collection</a>\n      <a class=\"ef2-btn ef2-btn-s\" href=\"/collections/t-shirts\">Browse tees</a>\n    </div>\n    <div class=\"ef2-ticks\"><span>Free US shipping over $50</span><span>Printed to order</span><span>Easy 30-day returns</span></div>\n  </div>\n  <div class=\"ef2-collage\">\n    <div class=\"ef2-burst\"></div>\n    <div class=\"ef2-card ef2-c1\"><img src=\"https://cdn.shopify.com/s/files/1/0775/4799/5293/files/5203809346876278723_2048.jpg?v=1784658825&width=700\" alt=\"Ella Fellas graphic tee on model\" loading=\"eager\"></div>\n    <div class=\"ef2-card ef2-c2\"><img src=\"https://cdn.shopify.com/s/files/1/0775/4799/5293/files/13659113146871562860_2048.jpg?v=1784658095&width=700\" alt=\"Ella Fellas sunset hoodie\" loading=\"eager\"></div>\n    <div class=\"ef2-card ef2-c3\"><img src=\"https://cdn.shopify.com/s/files/1/0775/4799/5293/files/14998726495850199840_2048.jpg?v=1784659672&width=700\" alt=\"Ella Fellas trucker cap\" loading=\"lazy\"></div>\n    <div class=\"ef2-badge\">NEW DROP &starf;</div>\n  </div>\n